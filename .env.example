# Azure Arc K8s Demo — Environment Variables
# Copy this file to .env and fill in the values before deploying.
#
#   cp .env.example .env
#   # Edit .env with your values
#   source .env

# ─── Required ────────────────────────────────────────────────────────────────

# VM admin password (must meet Azure complexity requirements:
# 12+ chars, uppercase, lowercase, number, special character)
export ADMIN_PASSWORD=''

# ─── General ─────────────────────────────────────────────────────────────────

# Azure region
# export LOCATION='westeurope'

# Resource group name
# export RESOURCE_GROUP_NAME='rg-arc-k8s-demo'

# ─── VM ──────────────────────────────────────────────────────────────────────

# VM name
# export VM_NAME='vm-arc-k8s'

# VM size (min 4 vCPU / 16 GB recommended)
# export VM_SIZE='Standard_D4s_v5'

# VM admin username
# export ADMIN_USERNAME='arcadmin'

# ─── Networking ──────────────────────────────────────────────────────────────

# Virtual network CIDR
# export VNET_ADDRESS_PREFIX='10.0.0.0/16'

# Subnet CIDR
# export SUBNET_ADDRESS_PREFIX='10.0.1.0/24'

# ─── Arc / Kubernetes ────────────────────────────────────────────────────────

# Azure Arc connected cluster name
# export CLUSTER_NAME='arc-k8s-demo'

# K3s service CIDR IP for Connected Registry (must be in 10.43.0.0/16 range)
# export CONNECTED_REGISTRY_SERVICE_CLUSTER_IP='10.43.0.100'

# ─── Supporting services (names must be globally unique) ─────────────────────

# Azure Container Registry name (alphanumeric only)
# export ACR_NAME='arck8sdemoacr'

# Azure Key Vault name
# export KEY_VAULT_NAME='arck8sdemokv'

# ─── RBAC ────────────────────────────────────────────────────────────────────

# Entra Object ID of the user/group to assign Azure Arc Kubernetes Cluster Admin
export ARC_RBAC_ASSIGNEE_ID='37e873aa-6b73-4b4c-a64c-0210b12d909d'

# ─── Monitoring (Azure Monitor + Container Insights for Arc Grafana dashboards) ─

# Azure Monitor workspace name (Prometheus metrics)
# export AZURE_MONITOR_WORKSPACE_NAME='amw-arc-k8s-demo'

# Log Analytics workspace name (Container Insights logs)
# export LOG_ANALYTICS_WORKSPACE_NAME='law-arc-k8s-demo'
